
# App
APP_NAME=HMIS API
ENV=development
DEBUG=True
API_V1_PREFIX=/api/v1
BACKEND_PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://hmis:hmis@localhost:5432/hmis
DATABASE_NAME=hmis
DATABASE_PORT=5432
DATABASE_USER=hmis
DATABASE_PASSWORD=hmis

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=xxxxxxx-xxxx-xxxx-xxxx-xxxxxxxx
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS: list[str] = ["http://localhost:3000"]

# M-Pesa
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
